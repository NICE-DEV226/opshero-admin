# OpsHero Admin Panel — Environment Variables
# Copy to .env.local and fill in values

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Admin JWT secret (must match backend ADMIN_JWT_SECRET)
# Used only server-side for token validation
ADMIN_JWT_SECRET=change-me-256-bit-random-secret
